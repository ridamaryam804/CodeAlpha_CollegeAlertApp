<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="#FFCA9B"
    android:animateLayoutChanges="true">

    <!-- Saved Events Text with Center Alignment and Full Width Underline -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:layout_marginBottom="16dp">

        <TextView
            android:id="@+id/savedEventsTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Saved Events"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#333333"
            android:gravity="center"
            android:layout_marginBottom="8dp"/>


        <View
            android:id="@+id/savedUnderlineView"
            android:layout_width="match_parent"
            android:layout_height="3dp"
            android:background="#C76327"
            android:layout_marginHorizontal="16dp"/>

    </LinearLayout>


    <ListView
        android:id="@+id/savedListView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:dividerHeight="8dp"
        android:divider="@android:color/transparent"
        android:padding="4dp"
        android:background="@android:color/transparent"/>

</LinearLayout>