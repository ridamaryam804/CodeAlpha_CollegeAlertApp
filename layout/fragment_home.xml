<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FFCA9B"
    android:animateLayoutChanges="true">


    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="20dp"
        android:background="#FCAA67"
        android:alpha="0.95"
        android:animateLayoutChanges="true">

        <TextView
            android:id="@+id/campusAlertTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="CampusAlert"
            android:textColor="#333333"
            android:textSize="32sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif-black"
            android:shadowColor="#80000000"
            android:shadowDx="2"
            android:shadowDy="2"
            android:shadowRadius="3"
            android:alpha="0"
            android:scaleX="0.5"
            android:scaleY="0.5">


        </TextView>

        <TextView
            android:id="@+id/stayInformedText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Stay Informed"
            android:textColor="#FFFFFF"
            android:textSize="30sp"
        android:fontFamily="sans-serif-light"
        android:textStyle="italic"
        android:layout_marginTop="1dp"
        android:alpha="0"
        android:scaleX="0.5"
        android:scaleY="0.5" />
    </LinearLayout>


    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:background="#FCAA67"
        android:animateLayoutChanges="true">

        <EditText
            android:id="@+id/searchEditText"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_weight="1"
            android:hint="Search alerts..."
            android:fontFamily="sans-serif"
            android:layout_marginBottom="-5dp"
            android:textColorHint="#FCAA67"
            android:textColor="#333333"
            android:background="#FFFFFF"
            android:paddingLeft="20dp"
            android:paddingRight="20dp"
            android:drawableLeft="@android:drawable/ic_menu_search"
            android:drawablePadding="10dp"
            android:elevation="2dp"/>
    </LinearLayout>


    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="14dp"
        android:background="#FCAA67"
        android:animateLayoutChanges="true">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/chipAll"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:text="All"
                android:textColor="#C76327"
            android:textSize="14sp"
            android:fontFamily="sans-serif-medium"
            android:background="@drawable/chip_selected"
            android:paddingLeft="20dp"
            android:paddingRight="20dp"
            android:layout_marginRight="8dp"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"/>

            <TextView
                android:id="@+id/chipSeminars"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:text="Seminars"
                android:textColor="#C76327"
            android:textSize="14sp"
            android:fontFamily="sans-serif"
            android:background="@drawable/chip_unselected"
            android:paddingLeft="20dp"
            android:paddingRight="20dp"
            android:layout_marginRight="8dp"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"/>

            <TextView
                android:id="@+id/chipExams"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:text="Exams"
                android:textColor="#C76327"
            android:textSize="14sp"
            android:fontFamily="sans-serif"
            android:background="@drawable/chip_unselected"
            android:paddingLeft="20dp"
            android:paddingRight="20dp"
            android:layout_marginRight="8dp"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"/>

            <TextView
                android:id="@+id/chipFests"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:text="Fests"
                android:textColor="#C76327"
            android:textSize="14sp"
            android:fontFamily="sans-serif"
            android:background="@drawable/chip_unselected"
            android:paddingLeft="20dp"
            android:paddingRight="20dp"
            android:layout_marginRight="8dp"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"/>

            <TextView
                android:id="@+id/chipNotices"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:text="Notices"
                android:textColor="#C76327"
            android:textSize="14sp"
            android:fontFamily="sans-serif"
            android:background="@drawable/chip_unselected"
            android:paddingLeft="20dp"
            android:paddingRight="20dp"
            android:layout_marginRight="8dp"

            android:gravity="center"
            android:clickable="true"
            android:focusable="true"/>
        </LinearLayout>
    </HorizontalScrollView>

    <!-- Today's Events Header - CENTERED -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
    android:padding="16dp"
    android:background="#FFCA9B"
    android:animateLayoutChanges="true">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Today's Events"
        android:textColor="#333333"
        android:textSize="20sp"
        android:textStyle="bold"
        android:fontFamily="sans-serif-black" />

    <TextView
        android:id="@+id/todayCount"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="5"
        android:textColor="#C76327"
    android:textSize="16sp"
    android:fontFamily="sans-serif-medium"
    android:layout_marginLeft="8dp"
    android:layout_gravity="center_vertical" />
</LinearLayout>


<ListView
android:id="@+id/eventListView"
android:layout_width="match_parent"
android:layout_height="match_parent"
android:dividerHeight="8dp"
android:divider="@android:color/transparent"
android:padding="8dp"
android:paddingBottom="16dp"
android:animateLayoutChanges="true"
android:alpha="0.95"/>

    </LinearLayout>