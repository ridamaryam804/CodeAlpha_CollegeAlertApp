<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/eventCard"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:elevation="4dp"
    android:layout_margin="8dp"
    android:padding="16dp">

    <!-- Top Row: Type + NEW Tag + Save Icon -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="12dp">

        <TextView
            android:id="@+id/eventType"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="EXAM"
            android:textColor="#333333"
            android:textSize="12sp"
            android:textStyle="bold"
            android:background="#ffb38a"
        android:padding="4dp"
        android:paddingLeft="8dp"
        android:paddingRight="8dp"
        android:layout_marginRight="8dp" />

        <TextView
            android:id="@+id/newTag"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="NEW"
            android:textColor="#4CAF50"
            android:textSize="10sp"
            android:textStyle="bold"
            android:background="#E8F5E9"
            android:padding="2dp"
            android:paddingLeft="6dp"
            android:paddingRight="6dp"
            android:layout_marginRight="8dp"
            android:visibility="visible"/>

        <TextView
            android:id="@+id/saveIcon"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="☆"
            android:textSize="20sp"
            android:textColor="#999999"
            android:layout_weight="1"
            android:gravity="end"
            android:clickable="true"
            android:focusable="true"
            android:padding="8dp"/>
    </LinearLayout>

    <!-- Event Title -->
    <TextView
        android:id="@+id/eventTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="End Semester Examination"
        android:textColor="#333333"
        android:textSize="16sp"
        android:textStyle="bold"
        android:layout_marginBottom="4dp" />

    <!-- Description -->
    <TextView
        android:id="@+id/eventDescription"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Description will appear here"
        android:textColor="#666666"
        android:textSize="14sp"
        android:layout_marginBottom="12dp" />

    <!-- Oval Boxes for Date, Time, Venue -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="4dp">

        <!-- Date Box -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/oval_box"
            android:padding="8dp"
            android:paddingLeft="12dp"
            android:paddingRight="12dp"
            android:layout_marginRight="8dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📅"
                android:textSize="14sp"
                android:textColor="#666666"
                android:layout_marginRight="4dp" />

            <TextView
                android:id="@+id/eventDate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Feb 24"
                android:textColor="#666666"
                android:textSize="12sp" />
        </LinearLayout>

        <!-- Time Box -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/oval_box"
            android:padding="8dp"
            android:paddingLeft="12dp"
            android:paddingRight="12dp"
            android:layout_marginRight="8dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⏰"
                android:textSize="14sp"
                android:textColor="#666666"
                android:layout_marginRight="4dp" />

            <TextView
                android:id="@+id/eventTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="9:00 AM"
                android:textColor="#666666"
                android:textSize="12sp" />
        </LinearLayout>

        <!-- Venue Box -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/oval_box"
            android:padding="8dp"
            android:paddingLeft="12dp"
            android:paddingRight="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📍"
                android:textSize="14sp"
                android:textColor="#666666"
                android:layout_marginRight="4dp" />

            <TextView
                android:id="@+id/eventVenue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Exam Block"
                android:textColor="#666666"
                android:textSize="12sp" />
        </LinearLayout>
    </LinearLayout>

</LinearLayout>