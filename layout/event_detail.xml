<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="#FFCA9B">

    <!-- 🔴 YE SAB VIEWS HAIN -->

    <TextView
        android:id="@+id/detailEventType"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Event Type"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="#C76327"
        android:gravity="center"
        android:layout_marginBottom="16dp"/>

    <TextView
        android:id="@+id/detailEventTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Event Title"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="#333333"
        android:gravity="center"
        android:layout_marginBottom="24dp"/>

    <!-- 🔴 DESCRIPTION TEXTVIEW - YEH VISIBLE HONA CHAHIYE -->
    <TextView
        android:id="@+id/detailDescription"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Description"
        android:textSize="16sp"
        android:textColor="#666666"
        android:visibility="visible"
        android:layout_marginBottom="20dp"/>

    <TextView
        android:id="@+id/detailDate"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Date"
        android:textSize="16sp"
        android:textColor="#333333"
        android:drawableLeft="@android:drawable/ic_menu_today"
        android:drawablePadding="10dp"
        android:layout_marginBottom="12dp"/>

    <TextView
        android:id="@+id/detailTime"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Time"
        android:textSize="16sp"
        android:textColor="#333333"
        android:drawableLeft="@android:drawable/ic_menu_zoom"
        android:drawablePadding="10dp"
        android:layout_marginBottom="12dp"/>

    <TextView
        android:id="@+id/detailVenue"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Venue"
        android:textSize="16sp"
        android:textColor="#333333"
        android:drawableLeft="@android:drawable/ic_menu_mylocation"
        android:drawablePadding="10dp"
        android:layout_marginBottom="20dp"/>

    <Button
        android:id="@+id/detailSaveButton"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:text="Save Event"
        android:textColor="#FFFFFF"
        android:backgroundTint="#C76327"
        android:layout_marginTop="10dp"/>

</LinearLayout>