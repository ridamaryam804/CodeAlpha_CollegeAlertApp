<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FFCA9B">

    <!-- Month Year Header - Dark Orange -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:background="#C76327"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/prevMonthBtn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="◀"
            android:textSize="24sp"
            android:textColor="#FFFFFF"
            android:padding="8dp"
            android:clickable="true"
            android:focusable="true"/>

        <TextView
            android:id="@+id/currentMonthYear"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="March 2026"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:gravity="center"/>

        <TextView
            android:id="@+id/nextMonthBtn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="▶"
            android:textSize="24sp"
            android:textColor="#FFFFFF"
            android:padding="8dp"
            android:clickable="true"
            android:focusable="true"/>
    </LinearLayout>

    <!-- Week Days Header - Dark Orange Text -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:background="#FFFFFF"
        android:gravity="center">

        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Mon" android:gravity="center" android:textColor="#C76327" android:textStyle="bold"/>
        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Tue" android:gravity="center" android:textColor="#C76327" android:textStyle="bold"/>
        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Wed" android:gravity="center" android:textColor="#C76327" android:textStyle="bold"/>
        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Thu" android:gravity="center" android:textColor="#C76327" android:textStyle="bold"/>
        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Fri" android:gravity="center" android:textColor="#C76327" android:textStyle="bold"/>
        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Sat" android:gravity="center" android:textColor="#C76327" android:textStyle="bold"/>
        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Sun" android:gravity="center" android:textColor="#C76327" android:textStyle="bold"/>
    </LinearLayout>

    <!-- Calendar Grid Container -->
    <LinearLayout
        android:id="@+id/calendarGrid"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#FFFFFF"
        android:padding="8dp"/>

    <!-- 🔴 UPCOMING EVENTS SECTION -->
    <TextView
        android:id="@+id/upcomingTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Upcoming"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="#333333"
        android:padding="16dp"
        android:background="#FFCA9B"
        android:layout_marginTop="8dp"
        android:visibility="visible"/>

    <LinearLayout
        android:id="@+id/upcomingEventsLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="8dp"/>

    <!-- Selected Date Title -->
    <TextView
        android:id="@+id/selectedDateTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Selected Date Events"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="#333333"
        android:gravity="center"
        android:padding="16dp"
        android:background="#FFCA9B"
        android:layout_marginTop="8dp"/>

    <!-- No Events Message -->
    <TextView
        android:id="@+id/noEventsMessage"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="No events on this date"
        android:textSize="16sp"
        android:textColor="#666666"
        android:gravity="center"
        android:padding="20dp"
        android:background="#FFFFFF"
        android:visibility="gone"/>

    <ListView
        android:id="@+id/calendarEventsListView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:dividerHeight="8dp"
        android:divider="@android:color/transparent"
        android:padding="8dp"/>

</LinearLayout>